# Copy to .env.local for local dev. In Vercel, set these in Project Settings > Environment Variables.

# --- Day 1: Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated list of Telegram user IDs allowed to message the bot.
# The bot rejects all other users. REQUIRED — bot fails closed if unset.
ALLOWED_TELEGRAM_USER_IDS=

# --- Day 1: Cron auth (auto-generated by Vercel when crons exist; set manually to test locally) ---
CRON_SECRET=

# --- Day 1.5: Vercel AI Gateway (Claude via unified API) ---
AI_GATEWAY_API_KEY=

# --- Day 2: weather (no key needed — Open-Meteo) ---

# --- Day 3: Google Gmail + Calendar OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# --- Day 4: Notion ---
NOTION_TOKEN=
NOTION_TASKS_DB_ID=

# --- Day 6+: Database (Neon Postgres via Vercel Marketplace) ---
DATABASE_URL=
